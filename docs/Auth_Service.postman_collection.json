{
	"info": {
		"name": "Auth Service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:6001/auth-service"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": ["{{base_url}}"],
							"path": ["register"]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Extract access_token from Set-Cookie header and store it",
									"const setCookieHeaders = pm.response.headers.filter(h => h.key.toLowerCase() === 'set-cookie');",
									"",
									"for (const header of setCookieHeaders) {",
									"    const match = header.value.match(/access_token=([^;]+)/);",
									"    if (match) {",
									"        pm.environment.set('access_token', match[1]);",
									"        console.log('access_token saved to environment');",
									"    }",
									"}",
									"",
									"// Also store user_id from response body",
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    if (body.user_id) {",
									"        pm.environment.set('user_id', body.user_id);",
									"        console.log('user_id saved to environment');",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					},
					"response": []
				},
				{
					"name": "Validate Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "access_token={{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/validate?user_id={{user_id}}",
							"host": ["{{base_url}}"],
							"path": ["validate"],
							"query": [
								{
									"key": "user_id",
									"value": "{{user_id}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "access_token={{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"token\": \"{{access_token}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Health",
			"item": [
				{
					"name": "GET Health Check",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "JWKS",
			"item": [
				{
					"name": "GET JWKS",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/token/.well-known/jwks.json",
							"host": ["{{base_url}}"],
							"path": ["token", ".well-known", "jwks.json"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Role",
			"item": [
				{
					"name": "Add Role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role_name\": \"moderator\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/roles",
							"host": ["{{base_url}}"],
							"path": ["roles"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "User",
			"item": [
				{
					"name": "GET User Me",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "access_token={{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/users/me?user_id={{user_id}}",
							"host": ["{{base_url}}"],
							"path": ["users", "me"],
							"query": [
								{
									"key": "user_id",
									"value": "{{user_id}}"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	]
}
