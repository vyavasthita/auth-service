{
  "valid_token_validation": [
    {
      "description": "Get user details with valid token",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "valid.jwt.token"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678",
        "username": "dilip_sharma",
        "created_at": "2026-01-01 00:00:00",
        "claims": {
          "sub": "12345678-1234-5678-1234-567812345678",
          "username": "dilip_sharma",
          "exp": 9999999999
        }
      },
      "output": {
        "status_code": 200,
        "body": {
          "user_id": "12345678-1234-5678-1234-567812345678",
          "username": "dilip_sharma",
          "created_at": "2026-01-01 00:00:00"
        }
      }
    }
  ],
  "missing_cookie_validation": [
    {
      "description": "Get user details without cookie",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678"
      },
      "output": {
        "status_code": 401,
        "body": {
          "message": "Invalid or expired token."
        }
      }
    }
  ],
  "invalid_token_validation": [
    {
      "description": "Get user details with invalid token",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "expired.jwt.token"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678"
      },
      "output": {
        "status_code": 401,
        "body": {
          "message": "Invalid or expired token."
        }
      }
    }
  ]
}
