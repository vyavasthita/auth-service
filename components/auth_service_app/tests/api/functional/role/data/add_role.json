  ],
  "role_already_exists_validation": [
    {
      "description": "Add role that already exists",
      "input": {
        "headers": { "Content-Type": "application/json" },
        "body": { "role_name": "admin" }
      },
      "mock": {
        "role_name": "admin"
      },
      "output": {
