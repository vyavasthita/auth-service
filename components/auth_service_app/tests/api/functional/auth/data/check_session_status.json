{
  "active_session": [
    {
      "description": "Check session status for an active session",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "valid.jwt.token"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678"
      },
      "output": {
        "status_code": 200
      }
    }
  ],
  "missing_cookie": [
    {
      "description": "Check session status without cookie",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678"
      },
      "output": {
        "status_code": 422
      }
    }
  ],
  "inactive_session": [
    {
      "description": "Check session status for an inactive/revoked session",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "revoked.jwt.token"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678"
      },
      "output": {
        "status_code": 401
      }
    }
  ]
}
