{
  "invalid_request_validation": [
    {
      "description": "Missing all required fields",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {}
      },
      "output": {
        "status_code": 422
      }
    },
    {
      "description": "Missing password field",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "testuser"
        }
      },
      "output": {
        "status_code": 422
      }
    },
    {
      "description": "Missing username field",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "password": "password123"
        }
      },
      "output": {
        "status_code": 422
      }
    }
  ],
  "valid_request_validation": [
    {
      "description": "Login with valid credentials",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "dilip_sharma",
          "password": "password123"
        }
      },
      "mock": {
        "token": "mocked.jwt.token",
        "user_username": "dilip_sharma",
        "user_password_hash": "$2b$12$mockedhashvalue"
      },
      "output": {
        "status_code": 200,
        "body": {
          "message": "Login successful."
        },
        "cookie": "access_token"
      }
    }
  ],
  "user_not_found_validation": [
    {
      "description": "Login with non-existent user",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "nonexistent_user",
          "password": "password123"
        }
      },
      "output": {
        "status_code": 404,
        "body": {
          "message": "User with 'nonexistent_user' not found."
        }
      }
    }
  ]
}
