{
  "valid_token_validation": [
    {
      "description": "Validate a valid token",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "valid.jwt.token"
        }
      },
      "mock": {
        "user_id": "12345678-1234-5678-1234-567812345678",
        "username": "dilip_sharma",
        "claims": {
          "sub": "dilip_sharma",
          "exp": 9999999999
        }
      },
      "output": {
        "status_code": 200,
        "body": {
          "user_id": "12345678-1234-5678-1234-567812345678",
          "username": "dilip_sharma"
        }
      }
    }
  ],
  "missing_cookie_validation": [
    {
      "description": "Validate without cookie",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "output": {
        "status_code": 401,
        "body": {
          "message": "Invalid or expired token."
        }
      }
    }
  ],
  "invalid_token_validation": [
    {
      "description": "Validate an expired/invalid token",
      "input": {
        "headers": {
          "Content-Type": "application/json"
        },
        "cookie": {
          "access_token": "expired.jwt.token"
        }
      },
      "output": {
        "status_code": 401,
        "body": {
          "message": "Invalid or expired token."
        }
      }
    }
  ]
}
