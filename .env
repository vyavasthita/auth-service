# =============================================================================
# Auth Service — Shared Configuration
# =============================================================================
# Single source of truth for config shared across all services
# (API, database, Liquibase, smoke tests).
#
# Sensitive values (e.g. AUTH_SERVICE_MYSQL_ROOT_PASSWORD) must be
# exported as shell environment variables — do NOT put secrets here.
#
# For Kubernetes / Helm deployments, these map to ConfigMap entries.
# =============================================================================

# --- Database ---
MYSQL_DATABASE=auth_service
MYSQL_USER=root
MYSQL_PORT=3306
MYSQL_HOST_PORT=3308

# --- Service ---
SERVICE_NAME=auth-service
API_PORT=6001

# --- phpMyAdmin ---
PHPMYADMIN_HOST_PORT=6081

# --- Liquibase ---
LIQUIBASE_LOG_LEVEL=DEBUG

# --- Observability ---
OBSERVABILITY_NETWORK_NAME=oaas-observability-net
